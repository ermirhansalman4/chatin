rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Yardımcı Fonksiyonlar
    function signedIn() {
      return request.auth != null;
    }
    
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    
    function isPremiumUser() {
      return signedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPremium == true;
    }
    
    function isServerMember(serverId) {
      return signedIn() && 
        exists(/databases/$(database)/documents/servers/$(serverId)/members/$(request.auth.uid));
    }
    
    function getServerMember(serverId) {
      return get(/databases/$(database)/documents/servers/$(serverId)/members/$(request.auth.uid));
    }
    
    function isServerOwner(serverId) {
      return signedIn() && 
        get(/databases/$(database)/documents/servers/$(serverId)).data.ownerUid == request.auth.uid;
    }
    
    function isServerAdmin(serverId) {
      return isServerOwner(serverId) || 
        (isServerMember(serverId) && getServerMember(serverId).data.roles.hasAny(['admin', 'moderator']));
    }

    // --- KULLANICI KURALLARI ---
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) && 
        !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['isPremium', 'badges', 'role', 'createdAt', 'xp', 'level']);
    }

    // --- SUNUCU KURALLARI ---
    match /servers/{serverId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isServerAdmin(serverId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['ownerUid', 'createdAt']);
      allow delete: if isServerOwner(serverId);
      
      match /members/{memberId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update: if isServerAdmin(serverId) && 
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'joinedAt']);
        allow delete: if isServerAdmin(serverId) || isSelf(memberId);
      }
      
      match /roles/{roleId} {
        allow read: if isServerMember(serverId);
        allow write: if isServerAdmin(serverId);
      }

      match /joinRequests/{requestId} {
        allow read: if isServerAdmin(serverId) || isSelf(requestId);
        allow create: if signedIn();
        allow update: if isServerAdmin(serverId);
        allow delete: if isServerAdmin(serverId) || isSelf(requestId);
      }

      match /voice_members/{memberId} {
        allow read: if signedIn();
        allow write: if isSelf(memberId);
      }
    }

    // --- KANAL KURALLARI ---
    match /channels/{channelId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn();

      match /offers/{offerId} {
        allow read, write: if signedIn();
      }

      match /offers/{offerId}/offerCandidates/{candidateId} {
        allow read, write: if signedIn();
      }

      match /offers/{offerId}/answerCandidates/{candidateId} {
        allow read, write: if signedIn();
      }

      match /voice_members/{memberId} {
        allow read: if signedIn();
        allow write: if isSelf(memberId);
      }
    }

    // --- MESAJ KURALLARI ---
    match /messages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn() && 
        request.resource.data.uid == request.auth.uid;
      allow update: if signedIn() && resource.data.uid == request.auth.uid && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'createdAt', 'channelId']);
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // --- ÖZEL MESAJLAR (DM) ---
    match /direct_messages/{dmId} {
      allow read: if signedIn();
      allow create: if signedIn();
      
      match /messages/{msgId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      }
    }

    // --- ARKADAŞLIK İSTEKLERİ ---
    match /friend_requests/{requestId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if signedIn() && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
      allow delete: if signedIn() && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
    }

    // --- PREMIUM İSTEKLERİ ---
    match /premium_requests/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid);
    }
    
    match /vanityCodes/{code} {
      allow read: if true;
      allow write: if false;
    }

    match /auditLogs/{logId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // --- COLLECTION GROUP: DM Mesajları (Global DM Listener için) ---
    match /{path=**}/messages/{msgId} {
      allow read: if signedIn();
    }
  }
}
